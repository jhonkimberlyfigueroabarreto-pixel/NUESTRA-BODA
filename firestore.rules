rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /guests/{guestId} {
      allow read: if true;
      allow create, update: if isValidGuest(request.resource.data);
      allow delete: if true;
    }

    match /tables/{tableId} {
      allow read, write: if true;
    }

    match /rsvps/{rsvpId} {
      allow read, write: if true;
    }

    match /config/{configId} {
      allow read, write: if true;
    }

    match /gallery_photos/{photoId} {
      allow read, write: if true;
    }

    match /guest_photos/{photoId} {
      allow read, write: if true;
    }

    match /guestbook/{messageId} {
      allow read, write: if true;
    }

    function isValidGuest(data) {
      return data.id is string
        && data.firstName is string
        && data.firstName.size() > 0
        && data.lastName is string
        && data.lastName.size() > 0
        && data.quota is int
        && data.quota >= 1
        && (data.status == 'Pendiente' || data.status == 'Confirmado' || data.status == 'No asiste')
        && data.code is string
        && data.code.size() > 0
        && (!('phone' in data) || data.phone is string)
        && (!('email' in data) || data.email is string)
        && (!('tableName' in data) || data.tableName is string)
        && (!('notes' in data) || data.notes is string)
        && (!('wantsReminder' in data) || data.wantsReminder is bool);
    }
  }
}
